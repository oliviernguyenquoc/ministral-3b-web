# =============================
# Global / API tokens
# =============================
HF_TOKEN=
MISTRAL_API_KEY=

# =============================
# Shared prompt and teacher model
# =============================
PROMPT_FILE=../src/lib/analysis_prompt.txt
TEACHER_MODEL=mistral-medium-latest

# =============================
# build_v1_dataset.py
# =============================
TRAIN_OUT=train.jsonl
EVAL_OUT=eval.jsonl
EVAL_RATIO=0.02
MIN_EVAL=1000

N_MENTAL_HEALTH=20000
N_MEDICAL=20000
N_FINANCE_PF=20000
N_FINANCE_KU=20000
N_CONFESSIONS=20000
N_PROSOCIAL=15000

PUSHSHIFT_STREAM_SCAN_MAX=10000000
PUSHSHIFT_SHUFFLE_BUFFER=200000
N_PUSH_REL=30000
N_PUSH_FAM=30000
N_PUSH_TIFU=15000

N_NEG_ULTRACHAT=30000
MAX_CHARS=8000
WEAK_POSITIVE_SCORE=40
WEAK_POSITIVE_RISK=medium

# =============================
# train_q_lora.py
# =============================
MODEL_NAME=mistralai/Ministral-3B-Instruct
TRAIN_FILE=train_v2.jsonl
EVAL_FILE=eval_v2.jsonl
OUTPUT_DIR=./lora-privacy
ADAPTER_DIR=./lora-privacy-adapter
LOGGING_DIR=./runs
REPORT_TO=tensorboard
RESUME_FROM_CHECKPOINT=

LORA_R=32
LORA_ALPHA=64
LORA_DROPOUT=0.05
TARGET_MODULES=q_proj,k_proj,v_proj,o_proj

BATCH_SIZE=4
GRAD_ACCUM=4
MAX_SEQ_LEN=2048
LR=2e-4
EPOCHS=2
SAVE_STEPS=400
EVAL_STEPS=400
LOGGING_STEPS=25
WARMUP_RATIO=0.03
PACKING=false
SAVE_TOTAL_LIMIT=2
LOAD_BEST_MODEL_AT_END=true

LOAD_IN_4BIT=true
GRADIENT_CHECKPOINTING=true

# =============================
# export_onnx_and_push_hf.py
# =============================
